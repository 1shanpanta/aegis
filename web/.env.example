# Paste any YouTube share URL here. Works with unlisted videos too.
# Auto-normalized to the privacy-enhanced /embed/ form with related-video
# chrome stripped. All of these accepted:
#   https://www.youtube.com/watch?v=XXXXXXXXXXX
#   https://youtu.be/XXXXXXXXXXX
#   https://www.youtube.com/shorts/XXXXXXXXXXX
#   https://www.youtube.com/embed/XXXXXXXXXXX
#   https://www.youtube-nocookie.com/embed/XXXXXXXXXXX
# Or paste a Loom / Vimeo embed URL as-is.
VITE_DEMO_EMBED_URL=

# Alternative: direct MP4 / WebM URL for a native <video> element.
# Example: VITE_DEMO_VIDEO_URL="https://cdn.example.com/aegis-demo.mp4"
VITE_DEMO_VIDEO_URL=

# Optional poster image shown before the video plays.
VITE_DEMO_POSTER_URL=

# ---------------------------------------------------------------------------
# Privy authentication (https://dashboard.privy.io)
# ---------------------------------------------------------------------------
# Create a Privy app at https://dashboard.privy.io, copy the App ID, and paste
# below. When unset, the AuthButton in the top bar is hidden and the rest of
# the site continues to work anonymously (the in-browser simulator does not
# require auth).
VITE_PRIVY_APP_ID=

# Optional: Privy client ID, only required if you have a server-side
# configuration that pins a specific client. Leave blank for default usage.
VITE_PRIVY_CLIENT_ID=
